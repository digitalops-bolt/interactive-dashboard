PLAN.md
data_model_doc.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local config (machine-specific permissions)
.claude/settings.local.json

# Windows/WSL artifacts (the ADS separator can be an ASCII or Unicode colon)
*Zone.Identifier
