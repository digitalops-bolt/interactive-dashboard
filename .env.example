# --- Bolt Storage Dashboard — copy to .env.local and fill in ---

# BigQuery (server-only — never exposed to the client)
BIGQUERY_PROJECT_ID=cubbyboltdata
# Full service-account JSON as a single line, wrapped in single quotes:
# GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account",...}'
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Anthropic — powers the AI Management Briefing on /overview (server-only; never NEXT_PUBLIC_).
# If ANTHROPIC_API_KEY is empty the briefing still works, but falls back to a rules-based
# (non-narrated) summary. Set AI_BRIEFING_ENABLED=false to force the fallback (kill switch).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# AI_BRIEFING_ENABLED=false

# Scheduled briefing digest endpoint (GET /api/briefing). A long random secret; the caller
# (e.g. n8n → Slack/email) sends it as `Authorization: Bearer <secret>`. Server-only.
BRIEFING_WEBHOOK_SECRET=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/overview
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/overview

# PostHog (usage analytics — public ingestion key, safe as NEXT_PUBLIC)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# PostHog admin/usage tab (server-only — a Personal API key with READ scope; NEVER NEXT_PUBLIC)
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
# REST API host (app host, not ingestion). US default; use https://eu.posthog.com for EU.
POSTHOG_API_HOST=https://us.posthog.com

# App
ALLOWED_EMAIL_DOMAIN=boltstorage.com
