# --- Bolt Storage Dashboard — copy to .env.local and fill in ---

# BigQuery (server-only — never exposed to the client)
BIGQUERY_PROJECT_ID=cubbyboltdata
# Full service-account JSON as a single line, wrapped in single quotes:
# GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account",...}'
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/overview
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/overview

# App
ALLOWED_EMAIL_DOMAIN=boltstorage.com
